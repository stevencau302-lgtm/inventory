{
  "enabled": true,
  "name": "Auto Git Push",
  "description": "Automatically commits and pushes changes to GitHub whenever a file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git commit -m \"auto: update files\" && git push"
  }
}