{
  "enabled": true,
  "name": "Auto Push on Save",
  "description": "Otomatis commit dan push semua perubahan ke origin/main setiap ada file yang disimpan.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git commit -m \"auto: update files\" && git push origin main",
    "timeout": 120
  }
}